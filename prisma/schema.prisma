// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum EntryCategory {
  INCOME
  EXPENSE
  INVESTMENT_CONTRIBUTION
}

/// Categoria-mãe do lançamento (segunda camada de categorização, além de EntryCategory).
/// Só se aplica a lançamentos EXPENSE — usada para orçamento mensal por categoria.
enum ParentCategory {
  MORADIA
  ALIMENTACAO
  TRANSPORTE
  SAUDE
  LAZER
  EDUCACAO
  FINANCEIRO
}

enum GoalStatus {
  NOT_STARTED
  ON_TRACK
  BEHIND
  ACHIEVED
}

/// Ícone temático escolhido pelo usuário para o card da meta.
enum GoalIcon {
  VIAGEM
  CASA
  CARRO
  APOSENTADORIA
  GENERICO
}

enum AssetClass {
  RENDA_FIXA
  ACAO
  FII
  TESOURO_DIRETO
  FUNDO
  CRIPTO
  OUTRO
}

/// Objetivo ao qual o ativo está alocado — espelha as categorias da planilha original
/// (Reserva, Liberdade, Meta) para a consolidação "posição atual por objetivo".
enum AssetObjective {
  RESERVA_EMERGENCIA
  LIBERDADE_FINANCEIRA
  META
  OUTRO
}

enum SimulationType {
  FINANCIAR_VS_ALUGAR
  AMORTIZAR_VS_INVESTIR
  CONSORCIO_VS_FINANCIAMENTO
  MARCACAO_MERCADO
  CARRO
}

enum SheetType {
  STOCK
  FII
  STOCK_INTL
  ETF
}

enum FiiType {
  TIJOLO
  PAPEL
  HIBRIDO
  FUNDO_DE_FUNDOS
}

enum RateBasis {
  ANNUAL_252
  ANNUAL_365
  MONTHLY
}

/// Classes usadas na tela "Estratégia da Carteira" — mais granulares que AssetClass
/// (que continua sendo usada no cadastro de ativos individuais). A posição atual por
/// classe de estratégia é derivada de Asset.assetClass por uma função de mapeamento
/// padrão (ver lib/portfolio/strategy.ts), já que são taxonomias diferentes.
enum StrategyAssetClass {
  RENDA_FIXA_POS_FIXADA
  RENDA_FIXA_IPCA
  PREFIXADO
  ACOES_BRASIL
  FIIS
  EXTERIOR
  OUTROS
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  role         Role     @default(CLIENT)
  currency     String   @default("BRL")
  theme        String   @default("light")
  notifyBudgetAlerts Boolean @default(true)
  notifyLateGoals    Boolean @default(true)
  /// Proteção contra força bruta: erros de senha consecutivos e trava temporária.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  monthlyEntries       MonthlyEntry[]
  budgets              Budget[]
  customCategories     CustomCategory[]
  portfolioStrategy    PortfolioStrategy[]
  patrimonySnapshots   PatrimonySnapshot[]
  assets               Asset[]
  goals                Goal[]
  emergencyFund        EmergencyFund?
  planningParams       PlanningParams?
  simulations          Simulation[]
  analysisSheets       AnalysisSheet[]
  referenceRates       ReferenceRate[]
  yearlyConsolidations YearlyConsolidationCache[]
  accumulationCache    AccumulationProjectionCache[]
  transactionRules     TransactionCategoryRule[]
  passwordResetTokens  PasswordResetToken[]

  asAdvisorLinks AdvisorClientLink[] @relation("advisor")
  asClientLinks  AdvisorClientLink[] @relation("client")
}

/// Token de recuperação de senha. Guardamos só o HASH do token (nunca o valor cru) — o link
/// enviado por e-mail carrega o token, e aqui comparamos pelo hash. Vale 1 hora e uma vez só.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Regra aprendida de classificação de extrato (item 3 da Rodada 2): quando o usuário resolve
/// uma transação na fila de revisão, guardamos merchant → categoria para classificar sozinho
/// as próximas transações parecidas. `pattern` é a chave normalizada (ver normalizeMerchant).
model TransactionCategoryRule {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  pattern        String
  parentCategory ParentCategory
  subcategory    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, pattern])
  @@index([userId])
}

model AdvisorClientLink {
  id        String   @id @default(cuid())
  advisorId String
  clientId  String
  status    String // INVITED | ACTIVE | REVOKED
  advisor   User     @relation("advisor", fields: [advisorId], references: [id])
  client    User     @relation("client", fields: [clientId], references: [id])
  createdAt DateTime @default(now())

  @@unique([advisorId, clientId])
}

/// Tabela de premissas/taxas de referência editáveis (CDI, IPCA, Selic...).
/// userId nulo = taxa padrão global (seed do sistema).
model ReferenceRate {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  name          String
  rateValue     Decimal   @db.Decimal(12, 6)
  basis         RateBasis
  effectiveDate DateTime
  createdAt     DateTime  @default(now())

  @@index([userId])
}

/// Categoria-mãe personalizada, criada pelo próprio usuário quando as 7 categorias fixas
/// (ParentCategory) não bastam. Vive fora do enum de propósito — o usuário pode apagar uma
/// categoria personalizada a qualquer momento, o que não faria sentido pra um valor de enum
/// (exigiria migração toda vez). Um MonthlyEntry/Budget de despesa pertence a exatamente uma
/// categoria: ou uma ParentCategory fixa, ou uma CustomCategory — nunca as duas (invariante
/// de aplicação, no mesmo espírito pragmático da subcategoria "Outro", que também não é enum).
model CustomCategory {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  name          String
  icon          String
  createdAt     DateTime       @default(now())
  monthlyEntries MonthlyEntry[]
  budgets       Budget[]

  @@unique([userId, name])
}

/// Lançamento mensal — substitui as 12 abas Jan..Dez da planilha original.
model MonthlyEntry {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  year             Int
  month            Int
  category         EntryCategory
  parentCategory   ParentCategory?
  customCategoryId String?
  customCategory   CustomCategory? @relation(fields: [customCategoryId], references: [id])
  subcategory      String?
  description      String?
  amount           Decimal         @db.Decimal(18, 2)
  /// Data em que a despesa/renda de fato aconteceu (opcional — lançamentos antigos não têm).
  /// year/month continuam sendo a verdade para a consolidação mensal; entryDate refina o dia.
  entryDate        DateTime?       @db.Date
  goalId           String?
  goal             Goal?           @relation(fields: [goalId], references: [id])
  createdAt        DateTime        @default(now())

  @@index([userId, year, month])
  @@index([userId, parentCategory])
  @@index([userId, customCategoryId])
}

/// Orçamento mensal planejado por categoria-mãe (para a barra "gasto realizado vs. planejado").
model Budget {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  year             Int
  month            Int
  parentCategory   ParentCategory?
  customCategoryId String?
  customCategory   CustomCategory? @relation(fields: [customCategoryId], references: [id])
  plannedAmount    Decimal         @db.Decimal(18, 2)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([userId, year, month, parentCategory, customCategoryId])
}

/// Cache opcional de consolidação anual (substitui Database -> Pivôs -> Consolidado do Ano).
/// Só deve ser preenchido/usado se aggregation queries diretas apresentarem latência real.
model YearlyConsolidationCache {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  year            Int
  totalIncome     Decimal  @db.Decimal(18, 2)
  totalExpense    Decimal  @db.Decimal(18, 2)
  totalInvestment Decimal  @db.Decimal(18, 2)
  balance         Decimal  @db.Decimal(18, 2)
  updatedAt       DateTime @updatedAt

  @@unique([userId, year])
}

/// Metas múltiplas (uma linha por meta na planilha original).
model Goal {
  id                  String         @id @default(cuid())
  userId              String
  user                User           @relation(fields: [userId], references: [id])
  name                String
  targetAmount        Decimal        @db.Decimal(18, 2)
  targetDate          DateTime?
  currentAmount       Decimal        @default(0) @db.Decimal(18, 2)
  monthlyContribution Decimal?       @db.Decimal(18, 2)
  annualRate          Decimal?       @db.Decimal(12, 6)
  status              GoalStatus     @default(NOT_STARTED)
  icon                GoalIcon       @default(GENERICO)
  entries             MonthlyEntry[]
  assets              Asset[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

/// Reserva de emergência.
model EmergencyFund {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  targetMonths        Int
  monthlyExpenseBase  Decimal  @db.Decimal(18, 2)
  targetAmount        Decimal  @db.Decimal(18, 2)
  currentAmount       Decimal  @default(0) @db.Decimal(18, 2)
  monthlyContribution Decimal  @db.Decimal(18, 2)
  annualRate          Decimal  @db.Decimal(12, 6)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Núcleo "Planejamento Financeiro" (acúmulo + usufruto).
model PlanningParams {
  id                              String   @id @default(cuid())
  userId                          String   @unique
  user                            User     @relation(fields: [userId], references: [id])
  currentAge                      Int
  retirementAge                   Int
  lifeExpectancyAge               Int?
  currentPatrimony                Decimal  @db.Decimal(18, 2)
  monthlyContributionAccumulation Decimal  @db.Decimal(18, 2)
  accumulationAnnualRate          Decimal  @db.Decimal(12, 6)
  inflationAnnualRate             Decimal  @db.Decimal(12, 6)
  usufructAnnualRate              Decimal  @db.Decimal(12, 6)
  desiredPassiveIncome            Decimal  @db.Decimal(18, 2)
  otherPassiveIncome              Decimal  @default(0) @db.Decimal(18, 2)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

/// Cache opcional da projeção ano a ano (equivalente "Base Dash acum").
model AccumulationProjectionCache {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  year              Int
  age               Int
  contributions     Decimal  @db.Decimal(18, 2)
  interestEarned    Decimal  @db.Decimal(18, 2)
  endingBalanceNom  Decimal  @db.Decimal(18, 2)
  endingBalanceReal Decimal  @db.Decimal(18, 2)
  updatedAt         DateTime @updatedAt

  @@unique([userId, year])
}

/// Minha Carteira.
model Asset {
  id                     String         @id @default(cuid())
  userId                 String
  user                   User           @relation(fields: [userId], references: [id])
  name                   String
  ticker                 String?
  assetClass             AssetClass
  objective              AssetObjective @default(OUTRO)
  goalId                 String?
  goal                   Goal?          @relation(fields: [goalId], references: [id])
  quantity               Decimal?       @db.Decimal(18, 6)
  currentUnitPrice       Decimal?       @db.Decimal(18, 6)
  /// Quanto foi investido (compra/aportes). A atualização de cotações NUNCA mexe aqui —
  /// é a referência fixa pro lucro/prejuízo (currentValue - investedValue).
  investedValue          Decimal?       @db.Decimal(18, 2)
  currentValue           Decimal        @db.Decimal(18, 2)
  idealAllocationPercent Decimal?       @db.Decimal(6, 3)
  acquisitionDate        DateTime?
  notes                  String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
}

/// Percentuais-alvo por classe de estratégia definidos pelo próprio usuário (soma = 100%),
/// independente da alocação-ideal por ativo individual em Asset.idealAllocationPercent.
model PortfolioStrategy {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  assetClass    StrategyAssetClass
  targetPercent Decimal            @db.Decimal(6, 3)
  updatedAt     DateTime           @updatedAt

  @@unique([userId, assetClass])
}

/// Snapshot diário do patrimônio total (soma de Asset.currentValue), gravado de forma
/// oportunista na primeira leitura do dia (ver lib/portfolio/snapshot.ts). É a única peça de
/// histórico real que o app guarda sobre patrimônio — sem ela não há como responder "quanto
/// cresceu" ou "é um novo recorde", já que Asset só guarda o valor atual.
model PatrimonySnapshot {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime @db.Date
  totalValue Decimal  @db.Decimal(18, 2)
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

/// Histórico opcional de simulações (financiar vs alugar, consórcio, marcação a mercado, carro).
model Simulation {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  type       SimulationType
  name       String?
  inputJson  Json
  outputJson Json
  createdAt  DateTime       @default(now())
}

/// Catálogo compartilhado de critérios das fichas de análise (Ações / FIIs).
/// Editável pela educadora (ADMIN) sem necessidade de deploy.
model AnalysisCriterionDefinition {
  id        String             @id @default(cuid())
  sheetType SheetType
  key       String
  label     String
  helpText  String? // tooltip "onde encontrar os dados"
  category  String // agrupamento qualitativo/quantitativo (ou TIJOLO/PAPEL/COMUM para FIIs)
  weight    Decimal?           @db.Decimal(6, 3)
  order     Int
  active    Boolean            @default(true)
  responses AnalysisResponse[]

  @@unique([sheetType, key])
}

/// Ficha de análise de Ações ou FIIs preenchida por um usuário.
model AnalysisSheet {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  sheetType    SheetType
  ticker       String
  companyName  String?
  fiiType      FiiType?
  analysisDate DateTime           @default(now())
  totalScore   Decimal?           @db.Decimal(8, 2)
  conclusion   String?
  responses    AnalysisResponse[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model AnalysisResponse {
  id          String                      @id @default(cuid())
  sheetId     String
  sheet       AnalysisSheet               @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  criterionId String
  criterion   AnalysisCriterionDefinition @relation(fields: [criterionId], references: [id])
  value       String?
  score       Decimal?                    @db.Decimal(6, 2)
  note        String?

  @@unique([sheetId, criterionId])
}
