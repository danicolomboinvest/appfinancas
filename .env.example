DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
AUTH_SECRET="generate-with: openssl rand -base64 32"

# E-mail transacional (boas-vindas + redefinir senha). Sem essas variáveis o app funciona,
# mas o "esqueci minha senha" vira um beco sem saída silencioso — configure antes de lançar.
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="contato@seudominio.com.br"
SMTP_PASSWORD=""

# Opcional: protege a rota /api/cron/quotes quando o agendador não é o cron da Vercel.
CRON_SECRET=""

# Acesso fechado: token compartilhado com o Hubla. É o MESMO valor que você cadastra no
# painel do Hubla (Webhooks) e aqui — o webhook /api/webhooks/hubla só aceita chamadas que
# tragam esse token no header x-hubla-token. Sem ele, o webhook recusa tudo (fail closed).
# Gere um valor aleatório: openssl rand -hex 32
HUBLA_WEBHOOK_TOKEN=""
